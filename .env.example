# ==========================
# Casanova Analytics - Env Vars
# ==========================
# Copie para .env.local e preencha os valores:
#   cp .env.example .env.local

# ── Auth ──
AUTH_SECRET=               # HMAC secret para assinar cookies (min 32 chars)

# ── Google Ads ──
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=    # Opcional (conta MCC)

# ── GA4 (Google Analytics 4) ──
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=                  # Chave privada do service account
GA4_PRIVATE_KEY_BASE64=           # Alternativa: base64-encode da chave (Vercel-friendly)

# ── Google Search Console ──
GSC_CLIENT_EMAIL=                 # Opcional: usa GA4_CLIENT_EMAIL como fallback
GSC_PRIVATE_KEY_BASE64=           # Base64-encode da chave (Vercel-friendly)
GSC_SITE_URL=                     # Ex: https://www.seusite.com.br

# ── Meta Ads ──
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=

# ── Instagram ──
INSTAGRAM_BUSINESS_ACCOUNT_ID=   # Opcional: auto-descoberto via Pages API

# ── Microsoft Clarity ──
CLARITY_PROJECT_ID=
CLARITY_API_TOKEN=

# ── Database (Prisma / Postgres) ──
DATABASE_URL=
DIRECT_URL=                       # Opcional (Prisma Accelerate)

# ── Seguranca ──
CREDENTIALS_ENCRYPTION_KEY=      # AES-256-GCM para criptografia de credenciais no DB
CRON_SECRET=                      # Secret para proteger endpoints /api/cron/*

# ── AI (Google Gemini / Claude) ──
GEMINI_API_KEY=
AI_ENABLED=true                   # true | false
AI_CHAT_MODEL=gemini-2.0-flash
AI_INSIGHTS_MODEL=gemini-2.0-flash
AI_STRATEGIC_MODEL=gemini-2.0-flash
AI_CHAT_RATE_LIMIT=30             # Requests por minuto
AI_INSIGHTS_RATE_LIMIT=12         # Requests por minuto
AI_INSIGHTS_CACHE_TTL=300         # Segundos
LLM_PROVIDER=gemini               # gemini | claude
